local tabButtons = {}
local tabPanels  = {}

local function switchTab(tabName)
    State.currentTab = tabName
    for _, name in ipairs(TABS) do
        local panel = tabPanels[name]
        local btn   = tabButtons[name]
        if panel then panel.Visible = (name == tabName) end
        if btn then
            if name == tabName then
                btn.BackgroundColor3 = Color3.fromRGB(0, 120, 40)
                btn.TextColor3       = Color3.fromRGB(0, 255, 80)
            else
                btn.BackgroundColor3 = Color3.fromRGB(4, 12, 4)
                btn.TextColor3       = Color3.fromRGB(0, 140, 50)
            end
        end
    end
end

for i, tabName in ipairs(TABS) do
    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(0, 100, 1, 0)
    btn.BackgroundColor3 = Color3.fromRGB(4, 12, 4)
    btn.BorderSizePixel  = 0
    btn.TextColor3       = Color3.fromRGB(0, 140, 50)
    btn.Font             = Enum.Font.Code
    btn.TextSize         = 11
    btn.Text             = tabName
    btn.LayoutOrder      = i
    btn.Parent           = TabBar
    tabButtons[tabName]  = btn
    tabPanels[tabName]   = createPanel(tabName)
    btn.MouseButton1Click:Connect(function() switchTab(tabName) end)
end

