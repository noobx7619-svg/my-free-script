local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local BanStore = DataStoreService:GetDataStore("AdminBanList")

local ADMIN_USERS = {
    ["YourUsernameHere"] = true,
}

local KickRemote = Instance.new("RemoteEvent")
KickRemote.Name   = "AdminKick"
KickRemote.Parent = ReplicatedStorage

local BanRemote = Instance.new("RemoteEvent")
BanRemote.Name   = "AdminBan"
BanRemote.Parent = ReplicatedStorage

-- Security: only accept requests from verified admins
local function isAdmin(player)
    return ADMIN_USERS[player.Name] == true
end

KickRemote.OnServerEvent:Connect(function(sender, targetName)
    if not isAdmin(sender) then return end
    local target = Players:FindFirstChild(targetName)
    if target then
        target:Kick("[ADMIN] You have been kicked by an administrator.")
    end
end)

BanRemote.OnServerEvent:Connect(function(sender, targetName)
    if not isAdmin(sender) then return end
    -- Save ban to DataStore
    pcall(function()
        BanStore:SetAsync(targetName, true)
    end)
    local target = Players:FindFirstChild(targetName)
    if target then
        target:Kick("[ADMIN] You have been permanently banned.")
    end
end)

-- Check ban on join
Players.PlayerAdded:Connect(function(player)
    local banned = false
    pcall(function()
        banned = BanStore:GetAsync(player.Name)
    end)
    if banned then
        player:Kick("[ADMIN] You are banned from this server.")
    end
end)

print("[ADMIN SERVER] Ready.")

