-- ============================================================
--  NOCLIP MODULE
-- ============================================================
local noclipConnection

local function enableNoclip()
    State.noclip = true
    noclipConnection = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
    notify("NOCLIP ON")
end

local function disableNoclip()
    State.noclip = false
    if noclipConnection then noclipConnection:Disconnect() end
    notify("NOCLIP OFF")
end

-- ============================================================
--  ESP MODULE
-- ============================================================
local function clearESP()
    for _, obj in ipairs(State.espObjects) do
        if obj and obj.Parent then obj:Destroy() end
    end
    State.espObjects = {}
end

local function enableESP()
    State.espEnabled = true
    local function addESP(player)
        if player == LocalPlayer then return end
        local char = player.Character or player.CharacterAdded:Wait()
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end

        local billboard = Instance.new("BillboardGui")
        billboard.Size         = UDim2.new(0, 120, 0, 36)
        billboard.StudsOffset  = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop  = true
        billboard.Adornee      = root
        billboard.Parent       = root

        local label = Instance.new("TextLabel")
        label.Size                     = UDim2.new(1, 0, 1, 0)
        label.BackgroundColor3         = Color3.fromRGB(10, 10, 10)
        label.BackgroundTransparency   = 0.3
        label.TextColor3               = Color3.fromRGB(0, 255, 120)
        label.Font                     = Enum.Font.Code
        label.TextScaled               = true
        label.Text                     = player.Name
        label.Parent                   = billboard

        local highlight = Instance.new("SelectionBox")
        highlight.Adornee              = char
        highlight.Color3               = Color3.fromRGB(0, 255, 100)
        highlight.LineThickness        = 0.05
        highlight.SurfaceTransparency  = 0.8
        highlight.SurfaceColor3        = Color3.fromRGB(0, 255, 100)
        highlight.Parent               = workspace

        table.insert(State.espObjects, billboard)
        table.insert(State.espObjects, highlight)
    end

    for _, p in ipairs(Players:GetPlayers()) do addESP(p) end
    Players.PlayerAdded:Connect(function(p)
        if State.espEnabled then addESP(p) end
    end)
    notify("ESP ON")
end

local function disableESP()
    State.espEnabled = false
    clearESP()
    notify("ESP OFF")
end

